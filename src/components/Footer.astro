---
interface Props {
  name?: string;
  location?: string;
  year?: number;
}
const { name = "Priyanka Navle", location = "Bengaluru, India", year = new Date().getFullYear() } = Astro.props;
---
<footer>
  <span>© {year} {name}</span>
  <span>{location}</span>
</footer>

<style>
  footer {
    background: var(--charcoal);
    padding: 1rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  footer span {
    font-size: 12px;
    color: #666;
  }
</style>
