---
interface Props {
  tag?: string;
  headline?: string;
  bio?: string;
  currentRole?: string;
  currentCompany?: string;
  location?: string;
  photoUrl?: string | null;
  photoAlt?: string;
}
const {
  tag = "Policy · Governance · Technology",
  headline = 'Building bridges between governments, <em>industry, and people.</em>',
  bio = "I'm Priyanka, a public policy professional with 8+ years navigating the intersection of gender & development, education, participatory governance, and technology.",
  currentRole = "Sr. Manager, Govt. Relations",
  currentCompany = "Cloudflare",
  location = "Bengaluru, India",
  photoUrl = null,
  photoAlt = "Photo of Priyanka",
} = Astro.props;
---
<div class="hero">
  <div class="hero-inner">
    <div class="hero-text">
      <p class="hero-tag">{tag}</p>
      <h1 set:html={headline} />
      <p class="hero-bio">{bio}</p>
      <div class="hero-stats-inline">
        <div>
          <p class="stat-label">Currently</p>
          <p class="stat-val">{currentRole} · {currentCompany}</p>
        </div>
        <div>
          <p class="stat-label">Based in</p>
          <p class="stat-val">{location}</p>
        </div>
      </div>
      <a href="#work" class="hero-cta">See my work →</a>
    </div>
    <div class="hero-photo-col">
      <div class="hero-photo">
        {photoUrl ? (
          <img src={photoUrl} alt={photoAlt} />
        ) : (
          <div class="hero-photo-placeholder">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#888" stroke-width="1.5">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
            <span>Photo of Priyanka</span>
          </div>
        )}
      </div>
    </div>
  </div>
</div>

<style>
  .hero {
    background: var(--charcoal);
    padding: 3rem 2rem 0;
    border-bottom: 1px solid #333;
    overflow: hidden;
  }
  .hero-inner {
    max-width: 860px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 220px;
    gap: 3rem;
    align-items: stretch;
    min-height: 420px;
  }
  .hero-text {
    padding-bottom: 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }
  .hero-tag {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }
  .hero h1 {
    font-family: var(--serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600;
    line-height: 1.15;
    color: var(--cream);
    margin-bottom: 1rem;
  }
  .hero h1 :global(em) {
    font-style: italic;
    font-weight: 400;
    color: #C4956A;
  }
  .hero-bio {
    font-size: 14px;
    color: #AAA;
    line-height: 1.8;
    margin-bottom: 1rem;
  }
  .hero-stats-inline {
    display: flex;
    gap: 2rem;
    margin-bottom: 1.5rem;
  }
  .stat-label {
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #555;
    margin-bottom: 0.15rem;
  }
  .stat-val {
    font-size: 12px;
    color: #CCC;
  }
  .hero-cta {
    display: inline-block;
    background: var(--accent);
    color: var(--cream);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.6rem 1.25rem;
    text-decoration: none;
    border-radius: 6px;
    width: fit-content;
  }
  .hero-photo-col {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }
  .hero-photo {
    width: 100%;
    flex: 1;
    min-height: 300px;
    background: #2E2E2C;
    border-radius: 12px 12px 0 0;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
  }
  .hero-photo-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    height: 100%;
  }
  .hero-photo-placeholder svg {
    opacity: 0.3;
  }
  .hero-photo-placeholder span {
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #555;
  }
</style>
